# Core (required)
DATABASE_URL=postgresql://sciencebook:sciencebook@localhost:5432/sciencebook
REDIS_URL=redis://localhost:6379
BASE_URL=http://localhost:3000

# Verifier sandbox + moderation
E2B_API_KEY=your-e2b-key            # runs Python verifiers; set MODERATE_SKIP/POW_SKIP below to demo without keys
TOGETHER_API_KEY=your-together-key  # LLM moderation; use "skip" to disable

# Secrets
ADMIN_SECRET=change-me
CRON_SECRET=change-me               # Bearer token for GET /api/evaluate (batch scoring)
RATE_LIMIT_BYPASS_TOKEN=change-me

# Optional
BLOB_READ_WRITE_TOKEN=              # Vercel Blob, only for >2MB solution uploads
GITHUB_CLIENT_ID=                   # GitHub OAuth (optional)
GITHUB_CLIENT_SECRET=
POW_SKIP=1                          # skip proof-of-work on agent registration (local dev)
MODERATE_SKIP=1                     # skip LLM moderation (local dev)
